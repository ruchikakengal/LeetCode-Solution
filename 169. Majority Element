class Solution {
public:
    int majorityElement(vector<int>& nums) {
        
        int count = 0;
        int candidate = 0;
        
        for(int num : nums) {
            if(count == 0)
                candidate = num;
            
            if(num == candidate)
                count++;
            else
                count--;
        }
        
        return candidate;
    }
};

********************

Approach: Boyer-Moore Voting Algorithm

Time Complexity: O(n)
Space Complexity: O(1)
